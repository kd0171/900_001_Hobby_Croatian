  "title_hr": "Mjere i jedinice",
  "sections": [
    {
      "id": "units",
      "title_ja": "買い物で使う単位",
      "note_ja": "量を頼む時は「数量 + 単位 + molim」の形が便利です。gram は数量によって grama になることが多いです。",
      "items": [
        {
          "ja": "グラム",
          "hr": "gram / grama",
          "pronunciation_ja": "グラム / グラマ",
          "note_ja": "100 grama, 500 grama"
        },
        {
          "ja": "キログラム",
          "hr": "kilogram / kilograma",
          "pronunciation_ja": "キログラム / キログラマ",
          "note_ja": "jedan kilogram, dva kilograma"
        },
        {
          "ja": "リットル",
          "hr": "litra / litre",
          "pronunciation_ja": "リトラ / リトレ",
          "note_ja": "jedna litra, dvije litre"
        },
        {
          "ja": "半分",
          "hr": "pola",
          "pronunciation_ja": "ポラ",
          "note_ja": "pola kilograma = 半キロ"
        },
        {
          "ja": "少し",
          "hr": "malo",
          "pronunciation_ja": "マロ",
          "note_ja": "malo soli = 少しの塩"
        },
        {
          "ja": "たくさん",
          "hr": "puno",
          "pronunciation_ja": "プノ",
          "note_ja": "puno ljudi = たくさんの人"
        },
        {
          "ja": "一切れ",
          "hr": "komad",
          "pronunciation_ja": "コマド",
          "note_ja": "komad ribe = 魚一切れ"
        }
      ],
      "examples": [
        {
          "ja": "500グラムください。",
          "hr": "Petsto grama, molim.",
          "pronunciation_ja": "ペトスト グラマ モリム",
          "note_ja": "魚市場でそのまま使える"
        },
        {
          "ja": "半キロください。",
          "hr": "Pola kilograma, molim.",
          "pronunciation_ja": "ポラ キログラマ モリム",
          "note_ja": "pola + 属格的な形"
        },
        {
          "ja": "水を1リットルください。",
          "hr": "Jednu litru vode, molim.",
          "pronunciation_ja": "イェドヌ リトル ヴォデ モリム",
          "note_ja": "水 vode は属格"
        },
        {
          "ja": "魚を二切れください。",
          "hr": "Dva komada ribe, molim.",
          "pronunciation_ja": "ドヴァ コマダ リベ モリム",
          "note_ja": "komad + ribe"
        },
        {
          "ja": "少しだけください。",
          "hr": "Samo malo, molim.",
          "pronunciation_ja": "サモ マロ モリム",
          "note_ja": "量を減らしたい時"
        }
      ]
    }
  ]
}