          "hr": "ponedjeljak",
          "pronunciation_ja": "ポネジェリャク",
          "note_ja": "曜日名"
        },
        {
          "ja": "火曜日",
          "hr": "utorak",
          "pronunciation_ja": "ウトラク",
          "note_ja": "曜日名"
        },
        {
          "ja": "水曜日",
          "hr": "srijeda",
          "pronunciation_ja": "スリイェダ",
          "note_ja": "曜日名"
        },
        {
          "ja": "木曜日",
          "hr": "četvrtak",
          "pronunciation_ja": "チェトヴルタク",
          "note_ja": "曜日名"
        },
        {
          "ja": "金曜日",
          "hr": "petak",
          "pronunciation_ja": "ペタク",
          "note_ja": "曜日名"
        },
        {
          "ja": "土曜日",
          "hr": "subota",
          "pronunciation_ja": "スボタ",
          "note_ja": "曜日名"
        },
        {
          "ja": "日曜日",
          "hr": "nedjelja",
          "pronunciation_ja": "ネジェリャ",
          "note_ja": "曜日名"
        }
      ],
      "examples": [
        {
          "ja": "今日は月曜日です。",
          "hr": "Danas je ponedjeljak.",
          "pronunciation_ja": "ダナス イェ ポネジェリャク",
          "note_ja": "Danas je + 曜日"
        },
        {
          "ja": "明日は火曜日です。",
          "hr": "Sutra je utorak.",
          "pronunciation_ja": "ストラ イェ ウトラク",
          "note_ja": "sutra = 明日"
        }
      ]
    },
    {
      "id": "weekdays_with_preposition",
      "title_ja": "前置詞+曜日",
      "note_ja": "「〜曜日に」は多くの場合 u + 曜日の形で表します。曜日によって語尾が変わるものがあります。",
      "items": [
        {
          "ja": "月曜日に",
          "hr": "u ponedjeljak",
          "pronunciation_ja": "ウ ポネジェリャク",
          "note_ja": "u + 曜日"
        },
        {
          "ja": "火曜日に",
          "hr": "u utorak",
          "pronunciation_ja": "ウ ウトラク",
          "note_ja": "u + 曜日"
        },
        {
          "ja": "水曜日に",
          "hr": "u srijedu",
          "pronunciation_ja": "ウ スリイェドゥ",
          "note_ja": "u + 曜日"
        },
        {
          "ja": "木曜日に",
          "hr": "u četvrtak",
          "pronunciation_ja": "ウ チェトヴルタク",
          "note_ja": "u + 曜日"
        },
        {
          "ja": "金曜日に",
          "hr": "u petak",
          "pronunciation_ja": "ウ ペタク",
          "note_ja": "u + 曜日"
        },
        {
          "ja": "土曜日に",
          "hr": "u subotu",
          "pronunciation_ja": "ウ スボトゥ",
          "note_ja": "u + 曜日"
        },
        {
          "ja": "日曜日に",
          "hr": "u nedjelju",
          "pronunciation_ja": "ウ ネジェリュ",
          "note_ja": "u + 曜日"
        }
      ],
      "examples": [
        {
          "ja": "土曜日に海へ行きます。",
          "hr": "Idemo na more u subotu.",
          "pronunciation_ja": "イデモ ナ モレ ウ スボトゥ",
          "note_ja": "u subotu = 土曜日に"
        },
        {
          "ja": "月曜日に市場へ行きます。",
          "hr": "Idem na tržnicu u ponedjeljak.",
          "pronunciation_ja": "イデム ナ トゥルジュニツ ダナス ウ ポネジェリャク",
          "note_ja": "予定を表す文"
        },
        {
          "ja": "日曜日に船はありますか？",
          "hr": "Ima li brod u nedjelju?",
          "pronunciation_ja": "イマ リ ブロド ウ ネジェリュ",
          "note_ja": "Ima li...? = ありますか"
        }
      ]
    },
    {
      "id": "date_basic",
      "title_ja": "日付の基本",
      "note_ja": "日付は序数と月名の属格形を使うことが多いです。初級では定型表現として覚えれば十分です。",
      "items": [
        {
          "ja": "今日は何日ですか？",
          "hr": "Koji je danas datum?",
          "pronunciation_ja": "コイ イェ ダナス ダトゥム",
          "note_ja": "日付を聞く表現"
        },
        {
          "ja": "今日は6月5日です。",
          "hr": "Danas je peti lipnja.",
          "pronunciation_ja": "ダナス イェ ペティ リプニャ",
          "note_ja": "5日 + 6月の属格"
        },
        {
          "ja": "明日",
          "hr": "sutra",
          "pronunciation_ja": "ストラ",
          "note_ja": "相対表現"
        },
        {
          "ja": "来週",
          "hr": "sljedeći tjedan",
          "pronunciation_ja": "スリェデチ ティエダン",
          "note_ja": "旅行予定で便利"
        },
        {
          "ja": "今週末",
          "hr": "ovaj vikend",
          "pronunciation_ja": "オヴァイ ヴィケンド",
          "note_ja": "週末の予定"
        }
      ],
      "examples": [
        {
          "ja": "船は6月5日に出発します。",
          "hr": "Brod polazi petog lipnja.",
          "pronunciation_ja": "ブロド ポラジ ペトグ リプニャ",
          "note_ja": "日付を含む出発文"
        },
        {
          "ja": "予約は7月12日です。",
          "hr": "Rezervacija je dvanaestog srpnja.",
          "pronunciation_ja": "レゼルヴァツィヤ イェ ドヴァナエストグ スルプニャ",
          "note_ja": "月は属格形"
        }
      ]
    },
    {
      "id": "date_examples",
      "title_ja": "日付を含む例文",
      "items": [
        {
          "ja": "7月に旅行します。",
          "hr": "Putujem u srpnju.",
          "pronunciation_ja": "プトゥイェム ウ スルプニュ",
          "note_ja": "u + 月の処格"
        },
        {
          "ja": "8月はとても暑いです。",
          "hr": "U kolovozu je jako vruće.",
          "pronunciation_ja": "ウ コロヴォズ イェ ヤコ ヴルチェ",
          "note_ja": "月を含む説明"
        },
        {
          "ja": "今週末、魚市場へ行きます。",
          "hr": "Ovaj vikend idem na ribarnicu.",
          "pronunciation_ja": "オヴァイ ヴィケンド イデム ナ リバルニツ",
          "note_ja": "予定表現"
        }
      ]
    }
  ]
}